@startuml AI工具系统-实现类图
' ============================================================
' AI 智能交互模块 — AI 工具系统类图
' 涵盖 smart-workshop-ai（框架）+ smart-workshop-server（工具实现）
' 作者: AI Module Design
' 日期: 2026-06-13
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F0F4FF
skinparam interfaceBackgroundColor #E8F5E9
skinparam enumBackgroundColor #FFF8E1
skinparam packageBackgroundColor #FAFAFA
skinparam stereotypeCBackgroundColor #E3F2FD
skinparam stereotypeIBackgroundColor #E8F5E9
skinparam linetype ortho

title AI 工具系统类图 — 框架层 + 15 个业务工具实现

' ============================================================
' 模块标识
' ============================================================
rectangle "smart-workshop-ai 模块\n（工具框架核心）" as AIModule #E3F2FD
rectangle "smart-workshop-server 模块\n（业务工具实现 + 权限桥接）" as ServerModule #C8E6C9

' ============================================================
' 注解层（框架层）
' ============================================================
AIModule .. annotation

package "annotation（注解）" as AnnotationPkg #FFF3E0 {
  annotation AiTool <<annotation>> {
    + name(): String
    + description(): String
    + category(): String
    + permissions(): String[]
    + requiresConfirmation(): boolean
    + label(): String
  }

  annotation ToolParam <<annotation>> {
    + description(): String
    + required(): boolean
    + enumValues(): String[]
  }
}

' ============================================================
' 工具框架核心（smart-workshop-ai）
' ============================================================
AIModule .. ToolFramework

package "agent（工具框架核心）" as ToolFramework #E0F2F1 {
  interface ToolHandler <<interface>> {
    + execute(params: Map, ctx: ToolContext): ToolResult
  }

  class ToolRegistry {
    - handlers: Map<String, ToolHandler>
    - metas: Map<String, AiToolMeta>
    - cachedDefinitions: List<Map>
    --
    + scan(): void
    + getToolDefinitions(): List<Map>
    + getHandler(toolName): ToolHandler
    + getMeta(toolName): AiToolMeta
    + getToolNames(): Set<String>
    + getToolCount(): int
  }

  class ToolExecutor {
    - toolRegistry: ToolRegistry
    - auditLogMapper: AiAuditLogMapper
    - metricsService: AiMetricsService
    - permissionChecker: PermissionChecker
    --
    + execute(toolName, params, ctx): ToolResult
    --- 7步沙箱管道 ---
    - {static} STEP_1_LOOKUP
    - {static} STEP_2_VALIDATE
    - {static} STEP_3_RBAC
    - {static} STEP_4_CONFIRM
    - {static} STEP_5_RATE_LIMIT
    - {static} STEP_6_EXECUTE
    - {static} STEP_7_AUDIT
  }

  class ToolContext {
    + userId: Integer
    + userName: String
    + sessionId: Long
    + messageId: Long
    + userNaturalInput: String
    + confirmed: boolean = false
    + permissionCodes: Set<String>
    + extra: Map<String, Object>
  }

  class ToolResult {
    + success: boolean
    + data: Object
    + errorMessage: String
    + needsConfirmation: boolean
    + confirmationMessage: String
    --
    + {static} success(data): ToolResult
    + {static} success(): ToolResult
    + {static} error(msg): ToolResult
    + {static} needsConfirmation(msg): ToolResult
    + toMap(): Map<String, Object>
  }

  class AiToolMeta {
    + name: String
    + label: String
    + description: String
    + category: String
    + permissions: String[]
    + requiresConfirmation: boolean
    + handlerClass: String
    + params: List<ToolParamMeta>
  }

  class AiToolMeta.ToolParamMeta {
    + name: String
    + description: String
    + required: boolean
    + jsonType: String
    + enumValues: String[]
  }

  class AiAuditLog {
    + id: Long
    + sessionId: Long
    + messageId: Long
    + userId: Integer
    + toolName: String
    + toolParams: String
    + executionResult: String
    + success: Boolean
    + errorMessage: String
    + durationMs: Integer
    + userNaturalInput: String
    + createdAt: LocalDateTime
  }
}

' ============================================================
' 权限桥接（smart-workshop-server）
' ============================================================
ServerModule .. PermissionBridge

package "config（权限桥接）" as PermissionBridge #BBDEFB {
  class AiPermissionBridge {
    - toolExecutor: ToolExecutor
    - authService: AuthService
    --
    + init(): void
  }

  class AuthService <<external>> {
    + getUserPermissionCodes(userId): Set<String>
  }
}

' ============================================================
' AI 工具实现 — BOM 管理
' ============================================================
ServerModule .. BomTools

package "tool.bom（BOM管理工具）" as BomTools #C8E6C9 {
  class CreateBomTool {
    --- @AiTool(name="create_bom") ---
    --- category: "BOM管理" ---
    --- permissions: SYS_BOM_MANAGE ---
    + bomDrawingNo: String <<@ToolParam(required)>>
    + bomNameSpec: String <<@ToolParam(required)>>
    + bomMaterial: String <<@ToolParam>>
    + bomQuantity: Integer <<@ToolParam>>
    + bomType: String <<@ToolParam(enumValues={"成品","半成品","原材料"})>>
    - bomService: bomService
    --
    + execute(params, ctx): ToolResult
  }

  class SearchBomTool {
    --- @AiTool(name="search_bom") ---
    --- category: "BOM管理" ---
    + keyword: String <<@ToolParam(required)>>
    - bomService: bomService
    --
    + execute(params, ctx): ToolResult
  }
}

